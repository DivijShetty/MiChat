# ════════════════════════════════════════════════
# MiChat — .gitignore
# Safe to push as a public repo with this file.
# ════════════════════════════════════════════════

# ── Firebase / API secrets ───────────────────────
# NEVER commit this. Copy firebase-config.example.js
# and fill in your keys locally.
firebase-config.js

# ── Environment files ────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Firebase CLI ─────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log

# ── Node (if you add a build step later) ─────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── OS junk ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor config ────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*~

# ── Build output (if you add Vite/webpack later) ──
dist/
build/
.cache/